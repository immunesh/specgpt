# ============================================================
# 5G SpecGPT - Environment Variables
# Copy this file to .env and fill in values
# ===========================================================

# Application
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Database
POSTGRES_DB=specgpt
POSTGRES_USER=specgpt_user
POSTGRES_PASSWORD=your_strong_password_here
DATABASE_URL=postgresql://specgpt_user:your_strong_password_here@localhost:5432/specgpt

# Redis
REDIS_PASSWORD=your_redis_password_here
REDIS_URL=redis://:your_redis_password_here@localhost:6379

# JWT Secrets (generate with: openssl rand -hex 64)
JWT_SECRET=your_jwt_secret_here_min_64_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here_min_64_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=application/pdf

# Embeddings (choose one provider)
# Voyage AI — recommended for technical docs (https://www.voyageai.com)
VOYAGE_API_KEY=pa-your-voyage-key-here
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-large-2
EMBEDDING_DIMENSIONS=1024

# OpenAI embeddings (alternative)
# OPENAI_API_KEY=sk-your-openai-key-here
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CHAT_RATE_LIMIT_MAX=20

# Email (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@5gspecgpt.com
